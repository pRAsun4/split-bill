# ─── Splitty App — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Expo, all variables MUST be prefixed with EXPO_PUBLIC_ to be accessible
# in client-side code via process.env.EXPO_PUBLIC_*

# ─── Backend API ──────────────────────────────────────────────────────────────

# Your backend base URL (no trailing slash)
# Development:   http://192.168.1.x:8000   (use your machine's LAN IP, not localhost)
# Production:    https://api.yourdomain.com
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# # API version prefix (if your backend uses /api/v1/...)
# EXPO_PUBLIC_API_VERSION=v1

# # ─── Auth ─────────────────────────────────────────────────────────────────────

# # Google OAuth Client ID (from Google Cloud Console)
# # Used for "Sign in with Google" button
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# # Token key name stored in AsyncStorage
# EXPO_PUBLIC_TOKEN_KEY=splitty_auth_token

# # ─── App Config ───────────────────────────────────────────────────────────────

# # App environment: development | staging | production
# EXPO_PUBLIC_APP_ENV=development

# # Request timeout in milliseconds
# EXPO_PUBLIC_API_TIMEOUT=10000
GitCode@2026



# EXPO_PUBLIC_API_URL=http://localhost:3001  # for browser testing (Expo Web)
EXPO_PUBLIC_API_URL=http://192.168.29.84:3001 # for mobile testing (use your machine's LAN IP, not localhost)

# API version prefix → final URL: {API_URL}/api/{API_VERSION}/auth/login
EXPO_PUBLIC_API_VERSION=v1

# Request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=10000

# ─── Auth ─────────────────────────────────────────────────────────────────────

# AsyncStorage key used to persist the JWT access token
EXPO_PUBLIC_TOKEN_KEY=splitty_auth_token

# Google OAuth Web Client ID (from Google Cloud Console)
# Leave blank until you implement Google Sign-In
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Socket.IO ────────────────────────────────────────────────────────────────

# WebSocket server URL — usually the same as API_URL (same server)
# Socket.IO connects directly to this URL (not /api/v1)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── App Config ───────────────────────────────────────────────────────────────

# Environment: development | staging | production
EXPO_PUBLIC_APP_ENV=development